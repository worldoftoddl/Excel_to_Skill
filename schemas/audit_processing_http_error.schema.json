{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audit_processing_http_error.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "error"],
  "properties": {
    "schema_version": {"const": "audit_processing_http_error.v1"},
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "enum": [
            "INVALID_REQUEST",
            "MISSING_IDEMPOTENCY_KEY",
            "UNSUPPORTED_MEDIA_TYPE",
            "LIMIT_EXCEEDED",
            "WORKBOOK_NOT_FOUND",
            "JOB_NOT_FOUND",
            "IDEMPOTENCY_CONFLICT",
            "JOB_IN_PROGRESS",
            "SCOPE_NOT_READY",
            "SCOPE_CONFLICT",
            "PLAN_CHANGED",
            "INVALID_SCOPE_SELECTION",
            "PROCESSING_PROFILE_CHANGED",
            "DETERMINISTIC_PROCESSING_FAILED",
            "PREPARATION_FAILED",
            "AGGREGATION_FAILED",
            "PUBLICATION_FAILED",
            "BUNDLE_UNAVAILABLE",
            "SERVICE_UNAVAILABLE",
            "INTERNAL_ERROR"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        }
      }
    }
  }
}
