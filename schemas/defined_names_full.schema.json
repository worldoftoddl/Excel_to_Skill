{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "defined_names_full.json (§4.0)",
  "description": "정의된 이름 전량 덤프. --full-names 시에만 존재하는 결정론 산출물. 카운트 4종은 diagnostics.defined_names와 같은 값. value는 전문(이메일만 P7 마스킹), name·scope는 원문, 순서는 추출 순서 보존.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "global_total",
    "sheet_scoped_total",
    "broken_ref_count",
    "legacy_path_count",
    "names"
  ],
  "properties": {
    "global_total": { "type": "integer", "minimum": 0 },
    "sheet_scoped_total": { "type": "integer", "minimum": 0 },
    "broken_ref_count": { "type": "integer", "minimum": 0 },
    "legacy_path_count": { "type": "integer", "minimum": 0 },
    "names": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "scope", "value", "flags"],
        "properties": {
          "name": { "type": "string" },
          "scope": { "type": ["string", "null"] },
          "value": { "type": ["string", "null"] },
          "flags": {
            "type": "array",
            "items": { "enum": ["broken_ref", "legacy_path"] }
          }
        }
      }
    }
  }
}
