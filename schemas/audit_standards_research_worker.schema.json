{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit standards research worker selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["abstained", "selected_candidate_refs"],
  "properties": {
    "abstained": {"type": "boolean"},
    "selected_candidate_refs": {
      "type": "array",
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^candidate:[0-9a-f]{64}$"
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"abstained": {"const": true}}},
      "then": {"properties": {"selected_candidate_refs": {"maxItems": 0}}}
    },
    {
      "if": {"properties": {"abstained": {"const": false}}},
      "then": {"properties": {"selected_candidate_refs": {"minItems": 1}}}
    }
  ]
}
