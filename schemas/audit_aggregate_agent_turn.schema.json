{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit aggregate main-agent turn",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "tool", "final"],
  "properties": {
    "action": {"enum": ["tool", "final"]},
    "tool": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/definitions/toolRequest"}
      ]
    },
    "final": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/definitions/finalResponse"}
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"action": {"const": "tool"}}},
      "then": {
        "properties": {
          "tool": {"$ref": "#/definitions/toolRequest"},
          "final": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"action": {"const": "final"}}},
      "then": {
        "properties": {
          "tool": {"type": "null"},
          "final": {"$ref": "#/definitions/finalResponse"}
        }
      }
    }
  ],
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "opaqueRef": {
      "type": "string",
      "pattern": "^(record|source):[0-9a-f]{64}$"
    },
    "toolRequest": {
      "type": "object",
      "description": "For standards_research set query, kind=\"audit_standard\" for KSA or kind=\"accounting_standard\" for K-IFRS, item_ref=null, one exact source scope_id, and limit=1..5. For procedure_planning set query, kind=null, item_ref=null, one exact source scope_id, limit=3..5, and include source_refs and research_refs. Refs merely linked inside an aggregate record are not observed source records: resolve them with source search/get/trace first. Copy refs only from typed observations; do not write proposed procedure prose here.",
      "additionalProperties": false,
      "required": ["name", "query", "kind", "item_ref", "scope_id", "limit"],
      "properties": {
        "name": {
          "enum": [
            "aggregate_search", "aggregate_get", "source_search",
            "assertion_procedures", "source_get", "trace", "standards_research",
            "procedure_planning"
          ]
        },
        "query": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 500
        },
        "kind": {
          "enum": [
            null, "statement", "limitation", "readiness_reason", "fact",
            "workpaper_attribute", "account", "risk", "assertion", "control",
            "procedure", "result", "finding", "conclusion", "open_item", "signoff",
            "documented_fact", "authoritative_context", "synthesis", "gap",
            "identity_scope", "risks_assertions", "controls", "procedures", "results",
            "findings", "conclusions", "open_items", "signoffs", "standards",
            "audit_standard", "accounting_standard"
          ]
        },
        "item_ref": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/definitions/opaqueRef"}
          ]
        },
        "scope_id": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/definitions/sha256"}
          ]
        },
        "limit": {"type": "integer", "minimum": 1, "maximum": 200},
        "source_refs": {
          "type": "array",
          "description": "Observed source refs from one exact aggregate source scope for one risk and one assertion.",
          "items": {"$ref": "#/definitions/opaqueRef"},
          "maxItems": 20,
          "uniqueItems": true
        },
        "research_refs": {
          "type": "array",
          "description": "Current-turn ephemeral research refs from the same source scope; otherwise an empty array.",
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^research:[0-9a-f]{64}$"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"name": {"const": "procedure_planning"}},
            "required": ["name"]
          },
          "then": {
            "required": ["source_refs", "research_refs"],
            "properties": {
              "query": {"type": "string", "minLength": 1, "maxLength": 500},
              "kind": {"type": "null"},
              "item_ref": {"type": "null"},
              "scope_id": {"$ref": "#/definitions/sha256"},
              "limit": {"type": "integer", "minimum": 3, "maximum": 5},
              "source_refs": {"minItems": 1}
            }
          }
        }
      ]
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "refs"],
      "properties": {
        "kind": {"enum": ["aggregate_record", "source_record"]},
        "refs": {
          "type": "array",
          "items": {"$ref": "#/definitions/opaqueRef"},
          "minItems": 1,
          "maxItems": 30,
          "uniqueItems": true
        }
      }
    },
    "finalResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["abstained", "abstention_code", "selections"],
      "properties": {
        "abstained": {"type": "boolean"},
        "abstention_code": {
          "enum": [
            "insufficient_evidence", "ambiguous_question", "retrieval_incomplete", null
          ]
        },
        "selections": {
          "type": "array",
          "items": {"$ref": "#/definitions/selection"},
          "maxItems": 30
        },
        "research_refs": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^research:[0-9a-f]{64}$"
          }
        },
        "plan_refs": {
          "type": "array",
          "maxItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^procedure-plan:[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
