{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit aggregate main-agent turn",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "tool", "final"],
  "properties": {
    "action": {"enum": ["tool", "final"]},
    "tool": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/definitions/toolRequest"}
      ]
    },
    "final": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/definitions/finalResponse"}
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"action": {"const": "tool"}}},
      "then": {
        "properties": {
          "tool": {"$ref": "#/definitions/toolRequest"},
          "final": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"action": {"const": "final"}}},
      "then": {
        "properties": {
          "tool": {"type": "null"},
          "final": {"$ref": "#/definitions/finalResponse"}
        }
      }
    }
  ],
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "opaqueRef": {
      "type": "string",
      "pattern": "^(record|source):[0-9a-f]{64}$"
    },
    "toolRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "query", "kind", "item_ref", "scope_id", "limit"],
      "properties": {
        "name": {
          "enum": [
            "aggregate_search", "aggregate_get", "source_search",
            "assertion_procedures", "source_get", "trace"
          ]
        },
        "query": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 500
        },
        "kind": {
          "enum": [
            null, "statement", "limitation", "readiness_reason", "fact",
            "workpaper_attribute", "account", "risk", "assertion", "control",
            "procedure", "result", "finding", "conclusion", "open_item", "signoff",
            "documented_fact", "authoritative_context", "synthesis", "gap",
            "identity_scope", "risks_assertions", "controls", "procedures", "results",
            "findings", "conclusions", "open_items", "signoffs", "standards"
          ]
        },
        "item_ref": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/definitions/opaqueRef"}
          ]
        },
        "scope_id": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/definitions/sha256"}
          ]
        },
        "limit": {"type": "integer", "minimum": 1, "maximum": 200}
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "refs"],
      "properties": {
        "kind": {"enum": ["aggregate_record", "source_record"]},
        "refs": {
          "type": "array",
          "items": {"$ref": "#/definitions/opaqueRef"},
          "minItems": 1,
          "maxItems": 30,
          "uniqueItems": true
        }
      }
    },
    "finalResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["abstained", "abstention_code", "selections"],
      "properties": {
        "abstained": {"type": "boolean"},
        "abstention_code": {
          "enum": [
            "insufficient_evidence", "ambiguous_question", "retrieval_incomplete", null
          ]
        },
        "selections": {
          "type": "array",
          "items": {"$ref": "#/definitions/selection"},
          "maxItems": 30
        }
      }
    }
  }
}
