{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audit_raw_workbook_snapshot.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workbook_id",
    "raw_snapshot_id",
    "workbook_sha256",
    "size_bytes",
    "status",
    "origin_kind",
    "prepared_bundle_created",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": "audit_raw_workbook_snapshot.v1"},
    "workbook_id": {
      "type": "string",
      "pattern": "^workbook-[0-9a-f]{48}$"
    },
    "raw_snapshot_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "workbook_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 67108864
    },
    "status": {"const": "stored"},
    "origin_kind": {"const": "upload"},
    "prepared_bundle_created": {"const": false},
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    }
  }
}
