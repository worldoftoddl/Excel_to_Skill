{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audit_workbook_edit_http_preview_request.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["office_revision_id", "worksheet_id", "before"],
  "properties": {
    "office_revision_id": {"$ref": "#/$defs/opaqueId"},
    "worksheet_id": {"$ref": "#/$defs/opaqueId"},
    "before": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"$ref": "#/$defs/cellState"}
    }
  },
  "$defs": {
    "opaqueId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "cell": {
      "type": "string",
      "pattern": "^[A-Z]{1,3}[1-9][0-9]*$"
    },
    "scalar": {
      "oneOf": [
        {"type": "string", "maxLength": 32767},
        {"type": "number", "minimum": -9007199254740991, "maximum": 9007199254740991},
        {"type": "boolean"}
      ]
    },
    "nullableScalar": {
      "oneOf": [
        {"$ref": "#/$defs/scalar"},
        {"type": "null"}
      ]
    },
    "authored": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {"kind": {"const": "blank"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {"const": "value"},
            "value": {"$ref": "#/$defs/scalar"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "formula"],
          "properties": {
            "kind": {"const": "formula"},
            "formula": {
              "type": "string",
              "minLength": 2,
              "maxLength": 8192,
              "pattern": "^="
            }
          }
        }
      ]
    },
    "cellState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cell", "authored", "calculated_value", "calculated_type",
        "number_format", "target_constraints"
      ],
      "properties": {
        "cell": {"$ref": "#/$defs/cell"},
        "authored": {"$ref": "#/$defs/authored"},
        "calculated_value": {"$ref": "#/$defs/nullableScalar"},
        "calculated_type": {
          "enum": ["empty", "string", "number", "boolean", "error"]
        },
        "number_format": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "target_constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["merged", "spill", "protected", "table_member"],
          "properties": {
            "merged": {"type": "boolean"},
            "spill": {"enum": ["none", "parent", "child"]},
            "protected": {"type": "boolean"},
            "table_member": {"type": "boolean"}
          }
        }
      }
    }
  }
}
