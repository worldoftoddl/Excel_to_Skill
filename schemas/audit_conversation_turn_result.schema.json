{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit_conversation_turn_result.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "thread_id",
    "turn_index",
    "resumed",
    "bundle",
    "response",
    "usage"
  ],
  "properties": {
    "schema_version": {"const": "audit_conversation_turn_result.v1"},
    "thread_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "turn_index": {"type": "integer", "minimum": 1, "maximum": 100},
    "resumed": {"type": "boolean"},
    "bundle": {"$ref": "#/definitions/bundle"},
    "response": {"type": "object"},
    "usage": {"$ref": "#/definitions/usage"}
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scope": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {"kind": {"const": "workbook"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "sheet", "id"],
          "properties": {
            "kind": {"const": "sheet"},
            "sheet": {"type": "string", "minLength": 1},
            "id": {"$ref": "#/definitions/sha256"}
          }
        }
      ]
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "workbook_sha256",
        "prepare_version",
        "facts_key",
        "standards_key",
        "brief_key",
        "prepared_at",
        "standards_corpus_version"
      ],
      "properties": {
        "scope": {"$ref": "#/definitions/scope"},
        "workbook_sha256": {"$ref": "#/definitions/sha256"},
        "prepare_version": {"type": "string", "minLength": 1},
        "facts_key": {"$ref": "#/definitions/sha256"},
        "standards_key": {"$ref": "#/definitions/sha256"},
        "brief_key": {"$ref": "#/definitions/sha256"},
        "prepared_at": {"type": "string", "minLength": 1},
        "standards_corpus_version": {"type": "string", "minLength": 1}
      }
    },
    "tokenDetails": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "usageEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "provider",
        "model",
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "event_id": {"type": "string", "pattern": "^request:[1-9][0-9]*$"},
        "provider": {"type": "string", "minLength": 1, "maxLength": 100},
        "model": {"type": "string", "minLength": 1, "maxLength": 200},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "input_token_details": {"$ref": "#/definitions/tokenDetails"},
        "output_token_details": {"$ref": "#/definitions/tokenDetails"}
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requests",
        "request_count",
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "requests": {
          "type": "array",
          "items": {"$ref": "#/definitions/usageEvent"},
          "maxItems": 12
        },
        "request_count": {"type": "integer", "minimum": 0, "maximum": 12},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      }
    }
  }
}
