{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit_workbook_edit_apply_manifest.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "manifest_ref", "manifest_sha256", "proposal_ref",
    "preview_ref", "approval_ref", "approval_expires_at", "execution_id",
    "fencing_token", "challenge_nonce", "status", "review_status",
    "application_status", "outside_prepared_bundle", "binding", "office_binding",
    "before", "before_sha256", "expected_after", "expected_after_sha256",
    "diff", "diff_sha256", "limitations"
  ],
  "properties": {
    "schema_version": {"const": "audit_workbook_edit_apply_manifest.v1"},
    "manifest_ref": {"type": "string", "pattern": "^edit-manifest:[0-9a-f]{64}$"},
    "manifest_sha256": {"$ref": "#/definitions/sha256"},
    "proposal_ref": {"type": "string", "pattern": "^edit-proposal:[0-9a-f]{64}$"},
    "preview_ref": {"type": "string", "pattern": "^edit-preview:[0-9a-f]{64}$"},
    "approval_ref": {"type": "string", "pattern": "^edit-approval:[0-9a-f]{64}$"},
    "approval_expires_at": {"type": "string", "minLength": 20, "maxLength": 64},
    "execution_id": {"$ref": "#/definitions/opaque"},
    "fencing_token": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "challenge_nonce": {"$ref": "#/definitions/opaque"},
    "status": {"const": "proposed"},
    "review_status": {"const": "unreviewed"},
    "application_status": {"const": "not_applied"},
    "outside_prepared_bundle": {"const": true},
    "binding": {"$ref": "#/definitions/binding"},
    "office_binding": {"$ref": "#/definitions/officeBinding"},
    "before": {"$ref": "#/definitions/beforeList"},
    "before_sha256": {"$ref": "#/definitions/sha256"},
    "expected_after": {"$ref": "#/definitions/authoredList"},
    "expected_after_sha256": {"$ref": "#/definitions/sha256"},
    "diff": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "#/definitions/diff"}},
    "diff_sha256": {"$ref": "#/definitions/sha256"},
    "limitations": {
      "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 300}
    }
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "opaque": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
    "cell": {"type": "string", "pattern": "^[A-Z]{1,3}[1-9][0-9]*$"},
    "scalar": {
      "oneOf": [
        {"type": "string"},
        {"type": "number", "minimum": -9007199254740991, "maximum": 9007199254740991},
        {"type": "boolean"}
      ]
    },
    "nullableScalar": {
      "oneOf": [
        {"$ref": "#/definitions/scalar"},
        {"type": "null"}
      ]
    },
    "scope": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "sheet", "id"],
      "properties": {
        "kind": {"const": "sheet"},
        "sheet": {"type": "string", "minLength": 1, "maxLength": 31},
        "id": {"$ref": "#/definitions/sha256"}
      }
    },
    "binding": {
      "type": "object", "additionalProperties": false,
      "required": ["bundle_id", "snapshot_id", "workbook_sha256", "scope"],
      "properties": {
        "bundle_id": {"$ref": "#/definitions/opaque"},
        "snapshot_id": {"$ref": "#/definitions/sha256"},
        "workbook_sha256": {"$ref": "#/definitions/sha256"},
        "scope": {"$ref": "#/definitions/scope"}
      }
    },
    "officeBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["session_id", "revision_id", "worksheet_id", "sheet"],
      "properties": {
        "session_id": {"$ref": "#/definitions/opaque"},
        "revision_id": {"$ref": "#/definitions/opaque"},
        "worksheet_id": {"$ref": "#/definitions/opaque"},
        "sheet": {"type": "string", "minLength": 1, "maxLength": 31}
      }
    },
    "authored": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"const": "blank"}}},
        {"type": "object", "additionalProperties": false, "required": ["kind", "value"], "properties": {"kind": {"const": "value"}, "value": {"$ref": "#/definitions/scalar"}}},
        {"type": "object", "additionalProperties": false, "required": ["kind", "formula"], "properties": {"kind": {"const": "formula"}, "formula": {"type": "string", "minLength": 2, "maxLength": 8192, "pattern": "^="}}}
      ]
    },
    "constraints": {
      "type": "object", "additionalProperties": false,
      "required": ["merged", "spill", "protected", "table_member"],
      "properties": {
        "merged": {"type": "boolean"},
        "spill": {"enum": ["none", "parent", "child"]},
        "protected": {"type": "boolean"},
        "table_member": {"type": "boolean"}
      }
    },
    "before": {
      "type": "object", "additionalProperties": false,
      "required": ["cell", "authored", "calculated_value", "calculated_type", "number_format", "target_constraints"],
      "properties": {
        "cell": {"$ref": "#/definitions/cell"},
        "authored": {"$ref": "#/definitions/authored"},
        "calculated_value": {"$ref": "#/definitions/nullableScalar"},
        "calculated_type": {"enum": ["empty", "string", "number", "boolean", "error"]},
        "number_format": {"type": "string", "minLength": 1, "maxLength": 500},
        "target_constraints": {"$ref": "#/definitions/constraints"}
      }
    },
    "beforeList": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "#/definitions/before"}},
    "authoredCell": {
      "type": "object", "additionalProperties": false,
      "required": ["cell", "authored", "number_format"],
      "properties": {
        "cell": {"$ref": "#/definitions/cell"},
        "authored": {"$ref": "#/definitions/authored"},
        "number_format": {"type": "string", "minLength": 1, "maxLength": 500}
      }
    },
    "authoredList": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "#/definitions/authoredCell"}},
    "diff": {
      "type": "object", "additionalProperties": false,
      "required": ["change_ref", "cell", "kind", "before", "after"],
      "properties": {
        "change_ref": {"type": "string", "pattern": "^edit-change:[0-9a-f]{64}$"},
        "cell": {"$ref": "#/definitions/cell"},
        "kind": {"enum": ["set_value", "set_formula", "set_number_format", "clear_contents"]},
        "before": {"$ref": "#/definitions/before"},
        "after": {"$ref": "#/definitions/authoredCell"}
      }
    }
  }
}
