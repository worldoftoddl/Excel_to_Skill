{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit_workbook_edit_proposal.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "proposal_ref", "proposal_sha256", "status",
    "review_status", "application_status", "outside_prepared_bundle",
    "binding", "changes"
  ],
  "properties": {
    "schema_version": {"const": "audit_workbook_edit_proposal.v1"},
    "proposal_ref": {"type": "string", "pattern": "^edit-proposal:[0-9a-f]{64}$"},
    "proposal_sha256": {"$ref": "#/definitions/sha256"},
    "status": {"const": "proposed"},
    "review_status": {"const": "unreviewed"},
    "application_status": {"const": "not_applied"},
    "outside_prepared_bundle": {"const": true},
    "binding": {"$ref": "#/definitions/binding"},
    "changes": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {"$ref": "#/definitions/change"}
    }
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "opaque": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"},
    "cell": {"type": "string", "pattern": "^[A-Z]{1,3}[1-9][0-9]*$"},
    "scalar": {
      "oneOf": [
        {"type": "string"},
        {"type": "number", "minimum": -9007199254740991, "maximum": 9007199254740991},
        {"type": "boolean"}
      ]
    },
    "scope": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "sheet", "id"],
      "properties": {
        "kind": {"const": "sheet"},
        "sheet": {"type": "string", "minLength": 1, "maxLength": 31},
        "id": {"$ref": "#/definitions/sha256"}
      }
    },
    "binding": {
      "type": "object", "additionalProperties": false,
      "required": ["bundle_id", "snapshot_id", "workbook_sha256", "scope"],
      "properties": {
        "bundle_id": {"$ref": "#/definitions/opaque"},
        "snapshot_id": {"$ref": "#/definitions/sha256"},
        "workbook_sha256": {"$ref": "#/definitions/sha256"},
        "scope": {"$ref": "#/definitions/scope"}
      }
    },
    "baseChange": {
      "type": "object",
      "required": ["change_ref", "cell", "kind"],
      "properties": {
        "change_ref": {"type": "string", "pattern": "^edit-change:[0-9a-f]{64}$"},
        "cell": {"$ref": "#/definitions/cell"}
      }
    },
    "change": {
      "oneOf": [
        {
          "allOf": [
            {"$ref": "#/definitions/baseChange"},
            {
              "type": "object", "additionalProperties": false,
              "required": ["change_ref", "cell", "kind", "value"],
              "properties": {
                "change_ref": {"type": "string", "pattern": "^edit-change:[0-9a-f]{64}$"},
                "cell": {"$ref": "#/definitions/cell"},
                "kind": {"const": "set_value"},
                "value": {"$ref": "#/definitions/scalar"}
              }
            }
          ]
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["change_ref", "cell", "kind", "formula"],
          "properties": {
            "change_ref": {"type": "string", "pattern": "^edit-change:[0-9a-f]{64}$"},
            "cell": {"$ref": "#/definitions/cell"},
            "kind": {"const": "set_formula"},
            "formula": {"type": "string", "minLength": 2, "maxLength": 8192, "pattern": "^="}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["change_ref", "cell", "kind", "number_format"],
          "properties": {
            "change_ref": {"type": "string", "pattern": "^edit-change:[0-9a-f]{64}$"},
            "cell": {"$ref": "#/definitions/cell"},
            "kind": {"const": "set_number_format"},
            "number_format": {"type": "string", "minLength": 1, "maxLength": 500}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["change_ref", "cell", "kind"],
          "properties": {
            "change_ref": {"type": "string", "pattern": "^edit-change:[0-9a-f]{64}$"},
            "cell": {"$ref": "#/definitions/cell"},
            "kind": {"const": "clear_contents"}
          }
        }
      ]
    }
  }
}
