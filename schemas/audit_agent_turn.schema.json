{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit briefing agent turn",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "tool", "final"],
  "properties": {
    "action": {
      "enum": ["tool", "final"]
    },
    "tool": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/definitions/toolRequest"}
      ]
    },
    "final": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/definitions/finalResponse"}
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"action": {"const": "tool"}}},
      "then": {
        "properties": {
          "tool": {"$ref": "#/definitions/toolRequest"},
          "final": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"action": {"const": "final"}}},
      "then": {
        "properties": {
          "tool": {"type": "null"},
          "final": {"$ref": "#/definitions/finalResponse"}
        }
      }
    }
  ],
  "definitions": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,127}$"
    },
    "identifierList": {
      "type": "array",
      "items": {"$ref": "#/definitions/identifier"},
      "uniqueItems": true,
      "maxItems": 100
    },
    "toolRequest": {
      "type": "object",
      "description": "For standards_research set query, kind=\"audit_standard\" for KSA or kind=\"accounting_standard\" for K-IFRS, item_id=null, and limit=1..5. For procedure_planning set query, kind=null, item_id=null, limit=3..5, and include fact_ids, relation_ids, standard_citation_ids, and research_refs. For workbook_inspection set query/kind/item_id null, limit=1, and provide one exact sheet/range, operation, and its strict parameters. IDs merely linked inside a brief statement are not observed records: trace or search/get first so each selected fact, relation, and citation appears as its own typed result. Copy refs only from typed observations; do not write proposed procedure prose here.",
      "additionalProperties": false,
      "required": ["name", "query", "kind", "item_id", "limit"],
      "properties": {
        "name": {
          "enum": [
            "audit_search",
            "audit_get",
            "assertion_procedures",
            "trace",
            "standards_research",
            "procedure_planning",
            "workbook_inspection"
          ]
        },
        "query": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 500
        },
        "kind": {
          "enum": [
            null,
            "fact", "statement",
            "workpaper_attribute", "account", "risk", "assertion", "control",
            "procedure", "result", "finding", "conclusion", "open_item", "signoff",
            "documented_fact", "authoritative_context", "synthesis", "gap",
            "identity_scope", "risks_assertions", "controls", "procedures", "results",
            "findings", "conclusions", "open_items", "signoffs", "standards",
            "audit_standard", "accounting_standard"
          ]
        },
        "item_id": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/definitions/identifier"}
          ]
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200
        },
        "fact_ids": {
          "type": "array",
          "description": "Observed workbook fact IDs for one planning target; include exactly one risk and one assertion.",
          "items": {"$ref": "#/definitions/identifier"},
          "maxItems": 20,
          "uniqueItems": true
        },
        "relation_ids": {
          "type": "array",
          "description": "Observed relation IDs that ground the planning target or existing procedures.",
          "items": {"$ref": "#/definitions/identifier"},
          "maxItems": 20,
          "uniqueItems": true
        },
        "standard_citation_ids": {
          "type": "array",
          "description": "Observed prepared standards citation IDs relevant to the planning target.",
          "items": {"$ref": "#/definitions/identifier"},
          "maxItems": 10,
          "uniqueItems": true
        },
        "research_refs": {
          "type": "array",
          "description": "Current-turn ephemeral research refs relevant to planning; otherwise an empty array.",
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^research:[0-9a-f]{64}$"
          }
        },
        "operation": {
          "enum": [
            "inspect_range", "inspect_formula_dependencies", "profile_table",
            "find_duplicates", "find_outliers"
          ]
        },
        "sheet": {"type": "string", "minLength": 1, "maxLength": 31},
        "range": {
          "type": "string",
          "pattern": "^[A-Za-z]{1,3}[1-9][0-9]{0,6}(:[A-Za-z]{1,3}[1-9][0-9]{0,6})?$",
          "maxLength": 25
        },
        "parameters": {"$ref": "#/definitions/inspectionParameters"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"name": {"const": "workbook_inspection"}},
            "required": ["name"]
          },
          "then": {
            "required": ["operation", "sheet", "range", "parameters"],
            "properties": {
              "query": {"type": "null"},
              "kind": {"type": "null"},
              "item_id": {"type": "null"},
              "limit": {"const": 1}
            }
          }
        }
        ,
        {
          "if": {
            "properties": {"name": {"const": "procedure_planning"}},
            "required": ["name"]
          },
          "then": {
            "required": [
              "fact_ids", "relation_ids", "standard_citation_ids", "research_refs"
            ],
            "properties": {
              "query": {"type": "string", "minLength": 1, "maxLength": 500},
              "kind": {"type": "null"},
              "item_id": {"type": "null"},
              "limit": {"type": "integer", "minimum": 3, "maximum": 5},
              "fact_ids": {"minItems": 1}
            }
          }
        }
      ]
    },
    "inspectionParameters": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["source", "limit"],
          "properties": {
            "source": {"enum": ["ledger", "raw"]},
            "limit": {"type": "integer", "minimum": 1, "maximum": 200}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["direction", "limit"],
          "properties": {
            "direction": {"enum": ["precedents", "dependents", "both"]},
            "limit": {"type": "integer", "minimum": 1, "maximum": 100}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["header"],
          "properties": {"header": {"type": "boolean"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["header", "columns", "limit"],
          "properties": {
            "header": {"type": "boolean"},
            "columns": {
              "type": "array", "minItems": 1, "maxItems": 10, "uniqueItems": true,
              "items": {"type": "string", "pattern": "^[A-Za-z]{1,3}$"}
            },
            "limit": {"type": "integer", "minimum": 1, "maximum": 50}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["header", "column", "limit"],
          "properties": {
            "header": {"type": "boolean"},
            "column": {"type": "string", "pattern": "^[A-Za-z]{1,3}$"},
            "limit": {"type": "integer", "minimum": 1, "maximum": 50}
          }
        }
      ]
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ids"],
      "properties": {
        "kind": {
          "enum": [
            "statement",
            "fact",
            "relation",
            "standard_citation"
          ]
        },
        "ids": {
          "type": "array",
          "items": {"$ref": "#/definitions/identifier"},
          "minItems": 1,
          "maxItems": 30,
          "uniqueItems": true
        }
      }
    },
    "finalResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "abstained",
        "abstention_code",
        "selections"
      ],
      "properties": {
        "abstained": {"type": "boolean"},
        "abstention_code": {
          "enum": [
            "insufficient_evidence",
            "ambiguous_question",
            "retrieval_incomplete",
            null
          ]
        },
        "selections": {
          "type": "array",
          "items": {"$ref": "#/definitions/selection"},
          "maxItems": 30
        },
        "research_refs": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^research:[0-9a-f]{64}$"
          }
        },
        "plan_refs": {
          "type": "array",
          "maxItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^procedure-plan:[0-9a-f]{64}$"
          }
        },
        "inspection_refs": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^inspection:[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
