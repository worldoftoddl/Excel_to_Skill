{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "audit_workbook_edit_http_propose_request.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "changes"],
  "properties": {
    "session_id": {"$ref": "#/$defs/opaqueId"},
    "changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"$ref": "#/$defs/change"}
    }
  },
  "$defs": {
    "opaqueId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "cell": {
      "type": "string",
      "pattern": "^[A-Z]{1,3}[1-9][0-9]*$"
    },
    "scalar": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 32767,
          "pattern": "^(?![\\t\\r\\n ]*[=+@-])"
        },
        {"type": "number", "minimum": -9007199254740991, "maximum": 9007199254740991},
        {"type": "boolean"}
      ]
    },
    "change": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["cell", "kind", "value"],
          "properties": {
            "cell": {"$ref": "#/$defs/cell"},
            "kind": {"const": "set_value"},
            "value": {"$ref": "#/$defs/scalar"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["cell", "kind", "formula"],
          "properties": {
            "cell": {"$ref": "#/$defs/cell"},
            "kind": {"const": "set_formula"},
            "formula": {
              "type": "string",
              "minLength": 2,
              "maxLength": 8192,
              "pattern": "^="
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["cell", "kind", "number_format"],
          "properties": {
            "cell": {"$ref": "#/$defs/cell"},
            "kind": {"const": "set_number_format"},
            "number_format": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["cell", "kind"],
          "properties": {
            "cell": {"$ref": "#/$defs/cell"},
            "kind": {"const": "clear_contents"}
          }
        }
      ]
    }
  }
}
